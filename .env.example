# ==============================================================================
#  Media Server Stack — Environment Variables
#  Copy this file to .env and fill in your values.
#  Docker Compose reads this file automatically.
#
#  To find your PUID and PGID, run: id
#  Timezone list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# ==============================================================================

# ------------------------------------------------------------------------------
#  User and system
# ------------------------------------------------------------------------------
PUID=1000
PGID=1000
TZ=America/New_York

# ------------------------------------------------------------------------------
#  Media paths
#  Set MEDIA_ROOT to wherever your media storage is mounted.
#  All library folders and the downloads folder will live under it.
#  Example: MEDIA_ROOT=/mnt/storage
# ------------------------------------------------------------------------------
MEDIA_ROOT=/srv/media
DOWNLOADS_DIR=/srv/downloads

# ------------------------------------------------------------------------------
#  Config paths
#  Where each service stores its config and database.
#  You can leave these as-is or move them to a different drive.
# ------------------------------------------------------------------------------
SONARR_CONFIG=/srv/sonarr/config
RADARR_CONFIG=/srv/radarr/config
PROWLARR_CONFIG=/srv/prowlarr/config
QBIT_CONFIG=/srv/qbittorrent/config
BAZARR_CONFIG=/srv/bazarr/config
SHOKO_CONFIG=/srv/shoko/config

# ------------------------------------------------------------------------------
#  qBittorrent credentials
#  On first startup, qBittorrent generates a temporary password
#  printed to the container log. The setup script reads this
#  automatically.
# ------------------------------------------------------------------------------
QBIT_USER=admin

# ------------------------------------------------------------------------------
#  Ports
#  Change these if you have conflicts with other services.
# ------------------------------------------------------------------------------
SERVER_IP=localhost
SONARR_PORT=8989
RADARR_PORT=7878
PROWLARR_PORT=9696
QBIT_PORT=8081
QBIT_TORRENT_PORT=6881
BAZARR_PORT=6767
SHOKO_PORT=8111
