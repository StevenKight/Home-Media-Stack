# Application Settings
APP_VERSION=1.0.0
APP_NAME="Magic the Gathering Deck Builder"
APP_DESCRIPTION="A storage and management platform for Magic the Gathering decks."

# Database Settings
# DATABASE_URL="sqlite+aiosqlite:///./app.db"

# PostgreSQL Configuration (Optional)
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=5432

# Database Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_ECHO=false
#DB_SSL_MODE=disable  # Options: disable, allow, prefer, require, verify-ca, verify-full

# CORS Settings
CORS_ORIGINS=["http://localhost:5173"]

# Environment
ENVIRONMENT=development  # Options: development, production, testing

# JWT Settings
SECRET_KEY=change_me_to_a_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Sonarr Settings
SONARR_HOST=localhost
SONARR_PORT=8989
SONARR_API_KEY=your_sonarr_api_key

# Radarr Settings
RADARR_HOST=localhost
RADARR_PORT=7878
RADARR_API_KEY=your_radarr_api_key
